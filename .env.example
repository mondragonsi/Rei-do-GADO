# ─────────────────────────────────────────────────────────────────────────────
# BovSmart — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório!
# ─────────────────────────────────────────────────────────────────────────────

# Porta do servidor Streamlit (padrão: 8501)
STREAMLIT_SERVER_PORT=8501

# Endereço do servidor (0.0.0.0 = aceita conexões externas)
STREAMLIT_SERVER_ADDRESS=localhost

# Nível de log: debug | info | warning | error
LOG_LEVEL=info

# Caminho para modelo YOLO customizado (opcional — deixe vazio para usar YOLOv8 padrão)
CUSTOM_MODEL_PATH=

# Pasta para salvar vídeos processados (opcional)
OUTPUT_FOLDER=./output

# Máximo de upload em MB (padrão Streamlit: 200)
MAX_UPLOAD_SIZE_MB=500
